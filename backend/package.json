{
  "name": "lorawan-device-monitor-backend",
  "type": "module",
  "main": "./main.js",
  "license": "UNLICENSED",
  "devDependencies": {
    "@perseid/dev-kit": "^10.0.0",
    "@types/better-sqlite3": "^7.6.11",
    "pino-pretty": "^13.0.0"
  },
  "eslintConfig": {
    "extends": [
      "./node_modules/@perseid/dev-kit/main.cjs"
    ],
    "overrides": [
      {
        "files": [
          "**/*.test.ts"
        ],
        "rules": {
          "@typescript-eslint/unbound-method": "off"
        }
      }
    ]
  },
  "dependencies": {
    "@fastify/static": "^8.0.3",
    "better-sqlite3": "^11.3.0",
    "fastify": "^5.7.2",
    "pino": "^9.5.0"
  },
  "devKitConfig": {
    "target": "node",
    "entries": {
      "main": "./scripts/main.ts"
    },
    "runInDev": true,
    "srcPath": "src",
    "distPath": "dist",
    "banner": "/*!\n * Copyright (c) MerciYanis.\n * All rights reserved.\n */"
  },
  "scripts": {
    "test": "node_modules/@perseid/dev-kit/scripts/test",
    "dev": "node node_modules/@perseid/dev-kit/scripts/dev",
    "check": "node node_modules/@perseid/dev-kit/scripts/check",
    "build": "node node_modules/@perseid/dev-kit/scripts/build --force",
    "postinstall": "rm -f node_modules/.eslintcache && mkdir -p node_modules/.cache"
  }
}
