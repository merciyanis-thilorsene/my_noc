# HTTP port the server listens on.
PORT=8080

# Path to the SQLite database file. The parent directory must be writable.
DATABASE_PATH=./data/monitor.db

# Shared secret TTS sends in the X-TTS-Webhook-Secret header.
# Provide either the value directly, or a path to a file containing it.
WEBHOOK_SECRET=change-me
# WEBHOOK_SECRET_FILE=/run/secrets/webhook_secret

# Optional, display-only TTS tenant identifier surfaced in the UI/health endpoint.
TTS_TENANT_ID=

# debug | info | warn | error
LOG_LEVEL=info

# How long to keep events before the daily cleanup deletes them.
RETENTION_DAYS=180

# Hour (UTC, 0-23) at which the daily retention cleanup runs.
CLEANUP_HOUR_UTC=3

# TTN/TTS cluster base URL for outbound downlinks (no trailing slash). Optional.
TTN_BASE_URL=https://eu1.cloud.thethings.network
# API key with downlink-write rights. Unset (with TTN_BASE_URL) disables downlinks.
# TTN_DOWNLINK_API_KEY=
# TTN_DOWNLINK_API_KEY_FILE=/run/secrets/ttn_downlink_api_key

# ── Gateways (Kerlink WMC) — Part B. All optional; unset any of the three below to
#    disable the gateway poller (gateways then come only from observed uplinks). ──
# WMC base URL (no trailing slash), e.g. https://wmc.wanesy.com
# WMC_BASE_URL=
# WMC_LOGIN=
# WMC_PASSWORD=
# WMC_PASSWORD_FILE=/run/secrets/wmc_password
# Seconds between gateway polls (default 300).
WMC_POLL_INTERVAL_SEC=300
# Shared secret for WMC's outbound alert webhook (configured on the WMC side).
# Unset disables the /webhooks/wmc/alerts endpoint entirely.
# WMC_ALERTS_WEBHOOK_SECRET=
# WMC_ALERTS_WEBHOOK_SECRET_FILE=/run/secrets/wmc_alerts_webhook_secret
# Nominatim-compatible geocoder for deployment address -> coordinates. Defaults to the
# public Nominatim; set empty to disable geocoding (manual coordinates still work).
# GEOCODER_URL=https://nominatim.openstreetmap.org
# Map tile URL template served to the frontend Gateways map.
# MAP_TILE_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png

# Shared access code gating the dashboard API (login screen until entered).
# Unset = open access. Webhooks + /api/health stay reachable. Value or _FILE path.
# ACCESS_CODE=
# ACCESS_CODE_FILE=/run/secrets/access_code
