# MerciYanis NOC — environment template
# Copy to `.env` and fill in. `.env` is gitignored.

# ==== General ====
NODE_ENV=production
LOG_LEVEL=info
COMPOSE_PROJECT_NAME=mynoc

# ==== Reverse proxy ====
PROXY_HTTP_PORT=8080
TRAEFIK_DASHBOARD=false
TRAEFIK_DASHBOARD_PORT=8081
TRAEFIK_LOG_LEVEL=INFO

# ==== TimescaleDB ====
POSTGRES_DB=noc
POSTGRES_USER=noc
POSTGRES_PASSWORD=change-me-to-a-strong-password

# ==== Redis ====
REDIS_PASSWORD=change-me-to-a-strong-password
REDIS_MAXMEMORY=128mb

# ==== The Things Stack (TTS) — optional in Commit A ====
TTS_BASE_URL=
TTS_API_KEY=
TTS_APP_IDS=
TTS_WEBHOOK_SECRET=
TTS_POLL_INTERVAL_SEC=300

# ==== Kerlink WMC — optional in Commit A ====
WMC_BASE_URL=
WMC_LOGIN=
WMC_PASSWORD=
WMC_POLL_INTERVAL_SEC=120

# ==== Frontend ↔ backend auth ====
# Comma-separated list of keys the backend will accept.
FRONTEND_API_KEYS=dev-key-change-me
CORS_ORIGINS=*

# Frontend backend URL at runtime. Leave empty for same-origin (recommended with the bundled Traefik).
FRONTEND_BACKEND_URL=

# ==== ML service (Phase 2, unused here) ====
ML_SERVICE_URL=
