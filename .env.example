# Copy to `.env` (gitignored) and fill in. Loaded by docker-compose into the container.
# Values here are injected as environment variables; `environment:` entries in
# docker-compose.yml take precedence over anything set here.

# ── TTN/TTS downlinks (Kuando Busylight control) ──────────────────────────────
# Cluster base URL of your TTN/TTS instance (no trailing slash).
TTN_BASE_URL=https://eu1.cloud.thethings.network
# API key with downlink-write rights (RIGHT_APPLICATION_TRAFFIC_DOWN_WRITE).
# Leave both unset to disable downlinks (the Control tab will report "not configured").
TTN_DOWNLINK_API_KEY=

# ── Gateways (Kerlink WMC) — Part B ───────────────────────────────────────────
# All optional. Leave the three WMC_* credentials unset to disable the poller:
# gateways then surface only from observed uplink traffic.
# WMC base URL (no trailing slash), e.g. https://wmc.wanesy.com
# WMC_BASE_URL=
# WMC_LOGIN=
# WMC_PASSWORD=
# Seconds between gateway polls (default 300).
# WMC_POLL_INTERVAL_SEC=300
# Shared secret for WMC's outbound alert webhook (configured in the WMC console,
# pointing at /webhooks/wmc/alerts). Unset disables the endpoint entirely.
# WMC_ALERTS_WEBHOOK_SECRET=
# Nominatim-compatible geocoder for deployment address -> coordinates.
# Defaults to the public Nominatim; set empty to disable (manual coordinates still work).
# GEOCODER_URL=https://nominatim.openstreetmap.org
# Map tile URL template for the Gateways map (defaults to OSM).
# MAP_TILE_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png

# ── Optional overrides ────────────────────────────────────────────────────────
# LOG_LEVEL=info
# RETENTION_DAYS=180
# CLEANUP_HOUR_UTC=3
# The webhook shared secret stays in ./secrets/webhook_secret.txt (Docker secret).
# To manage it here instead, set WEBHOOK_SECRET below and drop the `secrets:` block.
# WEBHOOK_SECRET=
